    "pr",
    "pull-request",
    "ai",
    "gemini",
    "cli"
  ],
  "license": "MIT",
  "files": [
    "dist"
  ],
  "dependencies": {
    "@google/generative-ai": "^0.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
