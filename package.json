{
  "name": "ai-git",
  "version": "1.0.0",
  "description": "AI-powered git commit and PR description generator using Gemini API",
  "main": "dist/index.js",
  "bin": {
    "ai-git": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
